// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid())
  firstName           String
  lastName            String
  email               String               @unique
  passwordHash        String
  company             String?
  isPaid              Boolean              @default(false)
  plan                PlanType             @default(FREE)
  analysisCount       Int                  @default(0)
  lastAnalysisDate    DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  passwordResetTokens PasswordResetToken[]
}

enum PlanType {
  FREE
  BASIC
  PRO
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Project {
  id          String     @id @default(uuid())
  name        String
  description String?
  decisions   Decision[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Person {
  id               String                   @id @default(uuid())
  email            String                   @unique
  name             String
  avatarUrl        String?
  responsibilities DecisionResponsibility[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

model Decision {
  id               String                   @id @default(uuid())
  content          String
  rationale        String?
  status           DecisionStatus           @default(PROPOSED)
  projectId        String
  project          Project                  @relation(fields: [projectId], references: [id])
  responsibilities DecisionResponsibility[]
  sourceId         String?
  source           Source?                  @relation(fields: [sourceId], references: [id])

  outgoingEdges    DecisionEdge[]           @relation("FromDecision")
  incomingEdges    DecisionEdge[]           @relation("ToDecision")

  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

enum DecisionStatus {
  PROPOSED
  FINALIZED
  REJECTED
  DEPRECATED
}

model DecisionResponsibility {
  id         String             @id @default(uuid())
  decisionId String
  personId   String
  role       ResponsibilityRole
  decision   Decision           @relation(fields: [decisionId], references: [id])
  person     Person             @relation(fields: [personId], references: [id])

  @@unique([decisionId, personId, role])
}

enum ResponsibilityRole {
  PROPOSER
  APPROVER
  STAKEHOLDER
  EXECUTOR
}

model DecisionEdge {
  id             String   @id @default(uuid())
  fromDecisionId String
  toDecisionId   String
  type           EdgeType
  fromDecision   Decision @relation("FromDecision", fields: [fromDecisionId], references: [id])
  toDecision     Decision @relation("ToDecision", fields: [toDecisionId], references: [id])

  @@unique([fromDecisionId, toDecisionId, type])
}

enum EdgeType {
  DEPENDS_ON
  RELATES_TO
  REFINES
  BLOCKS
}

model Source {
  id         String     @id @default(uuid())
  type       SourceType
  externalId String
  url        String?
  rawContent String?    @db.Text
  decisions  Decision[]
  createdAt  DateTime   @default(now())
}

enum SourceType {
  GOOGLE_MEET
}
